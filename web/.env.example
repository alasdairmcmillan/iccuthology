# Frontend config (Vite). Copy to .env.local to override.

# API base URL. Empty = same origin (the Cloudflare Worker serves both the
# static assets and /api/*). Set to e.g. http://localhost:8787 for a local worker.
VITE_API_BASE=

# Data source: "true" always use bundled fixtures, "false" always hit the API.
# Unset = fixtures in `npm run dev`, real API in a production build.
VITE_USE_FIXTURES=
